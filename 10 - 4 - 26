8. to find the grade using if switch statements 

#include<stdio.h>
void main()
{
    int m;
    scanf("%d",&m);
    switch(m/10)
    {
        case 10:
        case 9:
           printf("s");break;
        case 8:
           printf("a");break;
        case 7:
           printf("b");break;
        case 6:
           printf("c");break;
        case 5:
            if(m>=55)
               printf("d");
            else 
               printf("e");
               break;
        default:
           printf("fail");
    }
}

9. to differentiate the age group using switch statements

#include<stdio.h>
void main()
{
    int a,b;
    scanf("%d",&a);

    if(a>=1&&a<=12)
        b=1;
    else if(a>12&&a<=18)
        b=2;
    else if(a>18&&a<=30)
        b=3;
    else if(a>30&&a<=60)
        b=4;
    else if(a>60&&a<=100)
        b=5;
    else
        b=6;

    switch(b)
    {
        case 1:
          printf("child");break;
        case 2:
          printf("teen");break;
        case 3:
          printf("adult");break;
        case 4:
          printf("middle aged");break;
        case 5:
          printf("senior citizen");break;
        default:
          printf("burden");break;
    }
}

