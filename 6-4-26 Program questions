1.) WRITE A C PROGRAM TO FIND THE AREA OF A TRIANGLE.

#include <stdio.h>
void main() 
{
    int l,b,area;
    scanf("%d %d",&l,&b);
    area=l*b;
    printf("Area of triangle is = %d",area);
}

2.) C PROGRAM TO FIND SIMPLE INTREST .

#include <stdio.h>
void main() 
{
    int p,t,r,si;
    printf("give the inuputs for s,t,r respectively\n");
    scanf("%d %d %d",&p,&t,&r);
    si=p*t*r;
    printf("Simple interest is %d",si);
}

3.C PROGRAM TO CONVERT CELSIUS TO FAHRENHEIT .

#include <stdio.h>
void main() 
{
    float c,f;
    scanf("%f",&c);
    f=(1.8*c)+32;
    printf("fahrenheit = %f",f);
}

4. C PROG FOR FAHRENHEIT TO CELSIUS

#include <stdio.h>
int main() 
{
    float c,f;
    scanf("%f",&f);
    c=0.556*(f-32);
    printf("celsius = %f",c);
    return 0;
}

