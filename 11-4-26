1. USE WHILE LOOP TO PRINT HI TEN TIMES 

#include<stdio.h>
void main()
{
    int i=1;
    while(i<=10)
    {
        printf("hi\n");
        i++;
    }
}


2. USE FOR LOOP TO PRINT HI TEN TIMES

#include<stdio.h>
void main()
{
    int i;
    for(i=1;i<=10;i++)
        printf("hi\n");
}

3. USE C PROG TO PRINT 1 TO 10 USING WHILE LOOP

#include<stdio.h>
void main()
{
    int i=1;
    while(i<=10)
    {
        printf("%d\n",i);
        i++;
    }
}


4. WRITE C PROG TO PRITN 1 TO 10

#include<stdio.h>
void main()
{
    int i=10;
    while(i>=1)
    {
        printf("%d\n",i);
        i--;
    }
}

