11. PROG TO FIND THE FIBONACCI SERIES 

#include<stdio.h>
void main()
{
    int a=0,b=1,c,i=1,n;
    scanf("%d",&n);
    while(i<=n)
    {
        printf("%d\n",a);
        c=a+b;
        a=b;
        b=c;
        i++;
    }
}

12. PROG TO PRINT THE SUM OF EVEN NUMBERS OF THE FIBONACCI SERIES 

#include<stdio.h>
void main()
{
    int a=0,b=1,c,i=1,n,sum=0;
    scanf("%d",&n);
    while(i<=n)
    {
        if(a%2==0)
            sum=sum+a;
        c=a+b;
        a=b;
        b=c;
        i++;
    }
    printf("sum=%d",sum);
}

13. PROG TO PRINT THE SUM OF ODD NUMBERS OF THE FIBONACCI SERIES 

#include<stdio.h>
void main()
{
    int a=0,b=1,c,i=1,n,sum=0;
    scanf("%d",&n);
    while(i<=n)
    {
        if(a%2==0)
            sum=sum+a;
        c=a+b;
        a=b;
        b=c;
        i++;
    }
    printf("sum=%d",sum);
}

