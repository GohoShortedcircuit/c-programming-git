7. TO PRINT SUM OF N NATURAL NUMBERS

#include<stdio.h>
void main()
{
    int i=1,n,sum=0;
    scanf("%d",&n);
    while(i<=n)
    {
        sum=sum+i;
        i++;
    }
    printf("sum=%d",sum);
}

