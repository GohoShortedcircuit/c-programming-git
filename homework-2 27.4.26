1. Write a C program to Check if a given number is a perfect square or not.
#include<stdio.h>
void main()
{
    int n,i,f=0;
    scanf("%d",&n);
    for(i=1;i*i<=n;i++)
    {
        if(i*i==n)
            f=1;
    }
    if(f)
        printf("perfect square");
    else
        printf("not perfect");
}




2. Write a program to print all the prime numbers between a and b.
#include<stdio.h>
void main()
{
    int a,b,i,j,f;
    scanf("%d%d",&a,&b);
    for(i=a;i<=b;i++)
    {
        f=1;
        for(j=2;j<i;j++)
        {
            if(i%j==0)
                f=0;
        }
        if(f&&i>1)
            printf("%d\n",i);
    }
}




3. Write a program to print all the composite numbers between a and b.
#include<stdio.h>
void main()
{
    int a,b,i,j,f;
    scanf("%d%d",&a,&b);
    for(i=a;i<=b;i++)
    {
        f=0;
        for(j=2;j<i;j++)
        {
            if(i%j==0)
                f=1;
        }
        if(f)
            printf("%d\n",i);
    }
}




4. Write a C program to convert decimal to binary.
#include<stdio.h>
void main()
{
    int n,r,bin=0,p=1;
    scanf("%d",&n);
    while(n>0)
    {
        r=n%2;
        bin=bin+r*p;
        p=p*10;
        n=n/2;
    }
    printf("%d",bin);
}




5. Write a C program to convert binary to decimal.
#include<stdio.h>
void main()
{
    int n,r,dec=0,p=1;
    scanf("%d",&n);
    while(n>0)
    {
        r=n%10;
        dec=dec+r*p;
        p=p*2;
        n=n/10;
    }
    printf("%d",dec);
}




6. Write a C program to convert Binary to Octal Conversion.
#include<stdio.h>
void main()
{
    int n,r,oct=0,p=1;
    scanf("%d",&n);
    while(n>0)
    {
        r=n%10;
        oct=oct+r*p;
        p=p*8;
        n=n/10;
    }
    printf("%d",oct);
}




7. Write a C program to convert Octal to Binary Conversion.
#include<stdio.h>
void main()
{
    int n,r,bin=0,p=1;
    scanf("%d",&n);
    while(n>0)
    {
        r=n%8;
        bin=bin+r*p;
        p=p*10;
        n=n/8;
    }
    printf("%d",bin);
}




8. Write a C program to find the LCM of given two number.
#include<stdio.h>
void main()
{
    int a,b,m,i;
    scanf("%d%d",&a,&b);
    m=a>b?a:b;
    for(i=m;;i++)
    {
        if(i%a==0&&i%b==0)
        {
            printf("%d",i);
            break;
        }
    }
}




9. Write a C program to Find HCF of Two Numbers.
#include<stdio.h>
void main()
{
    int a,b,i,h=1;
    scanf("%d%d",&a,&b);
    for(i=1;i<=a&&i<=b;i++)
    {
        if(a%i==0&&b%i==0)
            h=i;
    }
    printf("%d",h);
}




10. Write a C program to Check the given number is a Spy Number or not.
#include<stdio.h>
void main()
{
    int n,r,s=0,p=1;
    scanf("%d",&n);
    while(n>0)
    {
        r=n%10;
        s=s+r;
        p=p*r;
        n=n/10;
    }
    if(s==p)
        printf("spy");
    else
        printf("not spy");
}
