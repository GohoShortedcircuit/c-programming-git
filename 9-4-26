10. c prog to find whether the given year is leap year or not using if else

#include<stdio.h>
void main()
{
    int y;
    scanf("%d",&y);
    if((y%4==0&&y%100!=0)||y%400==0)
        printf("Leap Year");
    else
        printf("Not Leap Year");
}
