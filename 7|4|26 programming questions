7.) swapping two numbers using temporary variable

#include<stdio.h>
int main()
{
    int a=10,b=20,t;
    printf("Before swap a=%d b=%d\n",a,b);
    t=a;
    a=b;
    b=t;
    printf("After swap a=%d b=%d",a,b);
    return 0;
}

8.) swapping two numbers without using temporary variable

#include<stdio.h>
int main()
{
    int a=10,b=20;
    printf("Before swap a=%d b=%d\n",a,b);
    a=a+b;
    b=a-b;
    a=a-b;
    printf("After swap a=%d b=%d",a,b);
    return 0;
}

